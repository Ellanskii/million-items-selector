{
  "name": "million-items-selector",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:frontend": "pnpm --filter @million-items-selector/frontend dev",
    "dev:backend": "pnpm --filter @million-items-selector/backend dev",
    "build": "pnpm --filter @million-items-selector/contracts build && pnpm generate:api && pnpm -r --filter=!@million-items-selector/contracts build",
    "generate:api": "pnpm --filter @million-items-selector/api-client generate",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
